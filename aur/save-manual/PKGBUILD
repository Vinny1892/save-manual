# Maintainer: Vinicius Espindola <vinnyaoe@gmail.com>
#
# Variante from-source: clona o repo numa tag, builda librclone via Go,
# builda a app via Tauri/Cargo, instala binário + librclone.so manualmente
# em /opt (lado a lado — libloading procura pelo nome direto, sem rpath).
#
# Pra usuários Arch puristas. Toma ~10 min (compilação Rust pesada).
# Quem quiser velocidade: use `save-manual-bin`.

pkgname=save-manual
_appname=save-sync
pkgver=0.1.0
pkgrel=1
pkgdesc="Replicação de save data entre instalações de emuladores"
arch=('x86_64' 'aarch64')
url="https://github.com/Vinny1892/save-manual"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'glibc')
optdepends=('libayatana-appindicator: tray icon support')
makedepends=('git' 'rust' 'nodejs' 'npm' 'go' 'gcc' 'patchelf' 'libsoup3' 'librsvg')
provides=("$_appname")
conflicts=("$_appname" 'save-manual-bin')

source=("$pkgname-$pkgver::git+$url.git#tag=v$pkgver")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  # Pre-cache dependências node — falha de rede no build() é frustrante.
  npm ci
}

build() {
  cd "$pkgname-$pkgver"

  # librclone (Go + cgo) — script detecta o triple via uname.
  bash scripts/build-librclone.sh

  # Frontend (SvelteKit) + binário Rust + Tauri bundle (deb). O Tauri
  # agora inclui librclone.so como resource em /usr/lib/<id>/, e o
  # rclone.rs tem fallback multi-path pra encontrá-lo após instalação.
  npm ci
  npx tauri build --target $(uname -m)-unknown-linux-gnu --bundles deb
}

package() {
  cd "$pkgname-$pkgver"

  # Extrai o .deb que Tauri produziu (já com layout correto:
  # binary em /usr/bin/, librclone.so em /usr/lib/com.savesync.app/,
  # .desktop e ícones nos lugares-padrão).
  local deb
  deb=$(ls src-tauri/target/*/release/bundle/deb/*.deb 2>/dev/null | head -1)
  [ -n "$deb" ] || { echo "no .deb produced by tauri build" >&2; return 1; }

  bsdtar -xf "$deb" -C "$srcdir"
  bsdtar -xf "$srcdir"/data.tar.* -C "$pkgdir/"

  # LICENSE (Tauri não inclui no .deb)
  [ -f LICENSE ] && install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$_appname/LICENSE"
}
